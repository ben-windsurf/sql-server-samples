      <!-- Organizational Hierarchy -->
      <Hierarchy ID="Organization" Name="Organizational Hierarchy">
        <Description>Employee organizational hierarchy for sales analysis</Description>
        <Levels>
          <Level ID="Is Salesperson" Name="Is Salesperson" Ordinal="0">
            <SourceAttribute>Is Salesperson</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>true</MemberNamesUnique>
          </Level>
          <Level ID="Employee" Name="Employee" Ordinal="1">
            <SourceAttribute>Employee</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>true</MemberNamesUnique>
          </Level>
        </Levels>
      </Hierarchy>
      
