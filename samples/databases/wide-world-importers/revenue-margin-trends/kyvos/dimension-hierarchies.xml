<?xml version="1.0" encoding="UTF-8"?>
<DimensionHierarchies xmlns="http://schemas.microsoft.com/analysisservices/2003/engine">
  
  <!-- Date Dimension Hierarchies -->
  <Dimension ID="Date" Name="Date">
    <Hierarchies>
      
      <!-- Calendar Hierarchy -->
      <Hierarchy ID="Calendar" Name="Calendar Hierarchy">
        <Description>Standard calendar year hierarchy for trend analysis</Description>
        <Levels>
          <Level ID="Calendar Year" Name="Year" Ordinal="0">
            <SourceAttribute>Calendar Year</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>true</MemberNamesUnique>
          </Level>
          <Level ID="Calendar Quarter" Name="Quarter" Ordinal="1">
            <SourceAttribute>Calendar Quarter</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>false</MemberNamesUnique>
          </Level>
          <Level ID="Calendar Month" Name="Month" Ordinal="2">
            <SourceAttribute>Calendar Month</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>false</MemberNamesUnique>
          </Level>
          <Level ID="Date" Name="Date" Ordinal="3">
            <SourceAttribute>Date</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>true</MemberNamesUnique>
          </Level>
        </Levels>
      </Hierarchy>
      
      <!-- Fiscal Hierarchy -->
      <Hierarchy ID="Fiscal" Name="Fiscal Hierarchy">
        <Description>Fiscal year hierarchy for financial reporting</Description>
        <Levels>
          <Level ID="Fiscal Year" Name="Fiscal Year" Ordinal="0">
            <SourceAttribute>Fiscal Year</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>true</MemberNamesUnique>
          </Level>
          <Level ID="Fiscal Quarter" Name="Fiscal Quarter" Ordinal="1">
            <SourceAttribute>Fiscal Quarter</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>false</MemberNamesUnique>
          </Level>
          <Level ID="Fiscal Month" Name="Fiscal Month" Ordinal="2">
            <SourceAttribute>Fiscal Month</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>false</MemberNamesUnique>
          </Level>
          <Level ID="Date" Name="Date" Ordinal="3">
            <SourceAttribute>Date</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>true</MemberNamesUnique>
          </Level>
        </Levels>
      </Hierarchy>
      
      <!-- Week Hierarchy -->
      <Hierarchy ID="Weekly" Name="Weekly Hierarchy">
        <Description>Weekly hierarchy for short-term trend analysis</Description>
        <Levels>
          <Level ID="Calendar Year" Name="Year" Ordinal="0">
            <SourceAttribute>Calendar Year</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>true</MemberNamesUnique>
          </Level>
          <Level ID="Calendar Week" Name="Week" Ordinal="1">
            <SourceAttribute>Calendar Week Label</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>false</MemberNamesUnique>
          </Level>
          <Level ID="Date" Name="Date" Ordinal="2">
            <SourceAttribute>Date</SourceAttribute>
            <HideMemberIf>Never</HideMemberIf>
            <MemberNamesUnique>true</MemberNamesUnique>
          </Level>
        </Levels>
      </Hierarchy>
      
    </Hierarchies>
  </Dimension>
  
