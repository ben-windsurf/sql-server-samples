            </KeyColumn>
          </KeyColumns>
          <NameColumn>
            <DataType>WChar</DataType>
            <Source xsi:type="ColumnBinding">
              <TableID>Dimension_Date</TableID>
              <ColumnID>Calendar_Day_Label</ColumnID>
            </Source>
          </NameColumn>
        </Attribute>
        
        <Attribute>
          <ID>Calendar Year</ID>
          <Name>Calendar Year</Name>
          <KeyColumns>
            <KeyColumn>
              <DataType>Integer</DataType>
              <Source xsi:type="ColumnBinding">
                <TableID>Dimension_Date</TableID>
                <ColumnID>Calendar_Year</ColumnID>
              </Source>
            </KeyColumn>
          </KeyColumns>
        </Attribute>
        
        <Attribute>
          <ID>Calendar Quarter</ID>
          <Name>Calendar Quarter</Name>
          <KeyColumns>
            <KeyColumn>
              <DataType>WChar</DataType>
              <Source xsi:type="ColumnBinding">
                <TableID>Dimension_Date</TableID>
                <ColumnID>Calendar_Quarter_Label</ColumnID>
              </Source>
            </KeyColumn>
          </KeyColumns>
        </Attribute>
        
        <Attribute>
          <ID>Calendar Month</ID>
          <Name>Calendar Month</Name>
          <KeyColumns>
            <KeyColumn>
              <DataType>WChar</DataType>
              <Source xsi:type="ColumnBinding">
                <TableID>Dimension_Date</TableID>
                <ColumnID>Calendar_Month_Label</ColumnID>
              </Source>
            </KeyColumn>
          </KeyColumns>
        </Attribute>
        
        <Attribute>
          <ID>Fiscal Year</ID>
          <Name>Fiscal Year</Name>
          <KeyColumns>
            <KeyColumn>
              <DataType>Integer</DataType>
              <Source xsi:type="ColumnBinding">
                <TableID>Dimension_Date</TableID>
                <ColumnID>Fiscal_Year</ColumnID>
              </Source>
            </KeyColumn>
          </KeyColumns>
        </Attribute>
      </Attributes>
      
      <!-- Date Hierarchies -->
      <Hierarchies>
        <Hierarchy>
          <ID>Calendar</ID>
          <Name>Calendar</Name>
          <Levels>
            <Level>
              <ID>Calendar Year</ID>
              <Name>Calendar Year</Name>
              <SourceAttributeID>Calendar Year</SourceAttributeID>
            </Level>
            <Level>
              <ID>Calendar Quarter</ID>
              <Name>Calendar Quarter</Name>
              <SourceAttributeID>Calendar Quarter</SourceAttributeID>
            </Level>
            <Level>
              <ID>Calendar Month</ID>
              <Name>Calendar Month</Name>
              <SourceAttributeID>Calendar Month</SourceAttributeID>
            </Level>
            <Level>
              <ID>Date</ID>
              <Name>Date</Name>
              <SourceAttributeID>Date</SourceAttributeID>
            </Level>
          </Levels>
        </Hierarchy>
        
        <Hierarchy>
          <ID>Fiscal</ID>
          <Name>Fiscal</Name>
          <Levels>
            <Level>
              <ID>Fiscal Year</ID>
              <Name>Fiscal Year</Name>
              <SourceAttributeID>Fiscal Year</SourceAttributeID>
            </Level>
            <Level>
              <ID>Calendar Month</ID>
              <Name>Fiscal Month</Name>
              <SourceAttributeID>Calendar Month</SourceAttributeID>
            </Level>
            <Level>
              <ID>Date</ID>
              <Name>Date</Name>
              <SourceAttributeID>Date</SourceAttributeID>
            </Level>
          </Levels>
        </Hierarchy>
      </Hierarchies>
    </Dimension>
    
    <!-- Customer Dimension -->
    <Dimension>
      <ID>Customer</ID>
      <Name>Customer</Name>
      <DimensionID>Customer</DimensionID>
      <Attributes>
        <Attribute>
          <ID>Customer</ID>
          <Name>Customer</Name>
          <KeyColumns>
            <KeyColumn>
              <DataType>Integer</DataType>
              <Source xsi:type="ColumnBinding">
                <TableID>Dimension_Customer</TableID>
                <ColumnID>Customer_Key</ColumnID>
              </Source>
            </KeyColumn>
          </KeyColumns>
          <NameColumn>
            <DataType>WChar</DataType>
            <Source xsi:type="ColumnBinding">
              <TableID>Dimension_Customer</TableID>
              <ColumnID>Customer</ColumnID>
            </Source>
          </NameColumn>
        </Attribute>
        
        <Attribute>
          <ID>Customer Category</ID>
          <Name>Customer Category</Name>
          <KeyColumns>
            <KeyColumn>
              <DataType>WChar</DataType>
              <Source xsi:type="ColumnBinding">
                <TableID>Dimension_Customer</TableID>
                <ColumnID>Category</ColumnID>
              </Source>
            </KeyColumn>
          </KeyColumns>
        </Attribute>
        
        <Attribute>
          <ID>Buying Group</ID>
          <Name>Buying Group</Name>
          <KeyColumns>
            <KeyColumn>
              <DataType>WChar</DataType>
              <Source xsi:type="ColumnBinding">
                <TableID>Dimension_Customer</TableID>
                <ColumnID>Buying_Group</ColumnID>
              </Source>
            </KeyColumn>
          </KeyColumns>
        </Attribute>
      </Attributes>
      
      <Hierarchies>
        <Hierarchy>
          <ID>Customer Hierarchy</ID>
          <Name>Customer Hierarchy</Name>
          <Levels>
            <Level>
              <ID>Customer Category</ID>
              <Name>Customer Category</Name>
              <SourceAttributeID>Customer Category</SourceAttributeID>
            </Level>
            <Level>
              <ID>Buying Group</ID>
              <Name>Buying Group</Name>
              <SourceAttributeID>Buying Group</SourceAttributeID>
            </Level>
            <Level>
              <ID>Customer</ID>
              <Name>Customer</Name>
              <SourceAttributeID>Customer</SourceAttributeID>
            </Level>
          </Levels>
        </Hierarchy>
      </Hierarchies>
    </Dimension>
    
    <!-- Stock Item Dimension -->
    <Dimension>
      <ID>Stock Item</ID>
      <Name>Stock Item</Name>
      <DimensionID>Stock Item</DimensionID>
      <Attributes>
        <Attribute>
          <ID>Stock Item</ID>
          <Name>Stock Item</Name>
          <KeyColumns>
            <KeyColumn>
              <DataType>Integer</DataType>
              <Source xsi:type="ColumnBinding">
                <TableID>Dimension_Stock_Item</TableID>
                <ColumnID>Stock_Item_Key</ColumnID>
              </Source>
            </KeyColumn>
          </KeyColumns>
          <NameColumn>
            <DataType>WChar</DataType>
            <Source xsi:type="ColumnBinding">
              <TableID>Dimension_Stock_Item</TableID>
              <ColumnID>Stock_Item</ColumnID>
            </Source>
          </NameColumn>
        </Attribute>
        
        <Attribute>
          <ID>Brand</ID>
          <Name>Brand</Name>
          <KeyColumns>
