  </Dimensions>
  
  <!-- Measure Groups -->
  <MeasureGroups>
    <MeasureGroup>
      <ID>Sale</ID>
      <Name>Sale</Name>
      <Source xsi:type="TableBinding">
        <TableID>Fact_Sale</TableID>
      </Source>
      
      <!-- Base Measures -->
      <Measures>
        <Measure>
          <ID>Revenue Excluding Tax</ID>
          <Name>Revenue Excluding Tax</Name>
          <AggregateFunction>Sum</AggregateFunction>
          <Source xsi:type="ColumnBinding">
            <TableID>Fact_Sale</TableID>
            <ColumnID>Total_Excluding_Tax</ColumnID>
          </Source>
          <FormatString>Currency</FormatString>
        </Measure>
        
        <Measure>
          <ID>Revenue Including Tax</ID>
          <Name>Revenue Including Tax</Name>
          <AggregateFunction>Sum</AggregateFunction>
          <Source xsi:type="ColumnBinding">
            <TableID>Fact_Sale</TableID>
            <ColumnID>Total_Including_Tax</ColumnID>
          </Source>
          <FormatString>Currency</FormatString>
        </Measure>
        
        <Measure>
          <ID>Profit</ID>
          <Name>Profit</Name>
          <AggregateFunction>Sum</AggregateFunction>
          <Source xsi:type="ColumnBinding">
            <TableID>Fact_Sale</TableID>
            <ColumnID>Profit</ColumnID>
          </Source>
          <FormatString>Currency</FormatString>
        </Measure>
        
        <Measure>
          <ID>Quantity</ID>
          <Name>Quantity</Name>
          <AggregateFunction>Sum</AggregateFunction>
          <Source xsi:type="ColumnBinding">
            <TableID>Fact_Sale</TableID>
            <ColumnID>Quantity</ColumnID>
          </Source>
          <FormatString>Standard</FormatString>
        </Measure>
        
        <Measure>
          <ID>Invoice Count</ID>
          <Name>Invoice Count</Name>
          <AggregateFunction>DistinctCount</AggregateFunction>
          <Source xsi:type="ColumnBinding">
            <TableID>Fact_Sale</TableID>
            <ColumnID>WWI_Invoice_ID</ColumnID>
          </Source>
          <FormatString>Standard</FormatString>
        </Measure>
      </Measures>
      
      <!-- Dimension Relationships -->
      <Dimensions>
        <Dimension xsi:type="RegularMeasureGroupDimension">
          <CubeDimensionID>Date</CubeDimensionID>
          <Attributes>
            <Attribute>
              <AttributeID>Date</AttributeID>
              <KeyColumns>
                <KeyColumn>
                  <DataType>DateTime</DataType>
                  <Source xsi:type="ColumnBinding">
                    <TableID>Fact_Sale</TableID>
                    <ColumnID>Invoice_Date_Key</ColumnID>
                  </Source>
                </KeyColumn>
              </KeyColumns>
            </Attribute>
          </Attributes>
        </Dimension>
        
        <Dimension xsi:type="RegularMeasureGroupDimension">
          <CubeDimensionID>Customer</CubeDimensionID>
          <Attributes>
            <Attribute>
              <AttributeID>Customer</AttributeID>
              <KeyColumns>
                <KeyColumn>
                  <DataType>Integer</DataType>
                  <Source xsi:type="ColumnBinding">
                    <TableID>Fact_Sale</TableID>
                    <ColumnID>Customer_Key</ColumnID>
                  </Source>
                </KeyColumn>
              </KeyColumns>
            </Attribute>
          </Attributes>
        </Dimension>
        
        <Dimension xsi:type="RegularMeasureGroupDimension">
          <CubeDimensionID>Stock Item</CubeDimensionID>
          <Attributes>
            <Attribute>
              <AttributeID>Stock Item</AttributeID>
              <KeyColumns>
                <KeyColumn>
                  <DataType>Integer</DataType>
                  <Source xsi:type="ColumnBinding">
                    <TableID>Fact_Sale</TableID>
                    <ColumnID>Stock_Item_Key</ColumnID>
                  </Source>
                </KeyColumn>
              </KeyColumns>
            </Attribute>
          </Attributes>
        </Dimension>
      </Dimensions>
    </MeasureGroup>
  </MeasureGroups>
  
  <!-- MDX Script with Calculated Measures -->
  <MdxScripts>
    <MdxScript>
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <Commands>
        <Command>
          <Text>
            CALCULATE;
            
            /* Margin Percentage Calculation */
            CREATE MEMBER CURRENTCUBE.[Measures].[Margin Percentage]
            AS [Measures].[Profit] / [Measures].[Revenue Excluding Tax] * 100,
            FORMAT_STRING = "0.00%",
            VISIBLE = 1;
            
            /* Year-over-Year Revenue Growth */
            CREATE MEMBER CURRENTCUBE.[Measures].[Revenue YoY Growth %]
            AS ([Measures].[Revenue Excluding Tax] - 
                ([Measures].[Revenue Excluding Tax], ParallelPeriod([Date].[Calendar].[Year], 1))) /
               ([Measures].[Revenue Excluding Tax], ParallelPeriod([Date].[Calendar].[Year], 1)) * 100,
            FORMAT_STRING = "0.00%",
            VISIBLE = 1;
            
            /* Month-over-Month Revenue Growth */
            CREATE MEMBER CURRENTCUBE.[Measures].[Revenue MoM Growth %]
            AS ([Measures].[Revenue Excluding Tax] - 
                ([Measures].[Revenue Excluding Tax], [Date].[Calendar].CurrentMember.PrevMember)) /
               ([Measures].[Revenue Excluding Tax], [Date].[Calendar].CurrentMember.PrevMember) * 100,
            FORMAT_STRING = "0.00%",
            VISIBLE = 1;
            
            /* Rolling 12-Month Revenue */
            CREATE MEMBER CURRENTCUBE.[Measures].[Rolling 12M Revenue]
            AS SUM(LastPeriods(12, [Date].[Calendar].[Month].CurrentMember), [Measures].[Revenue Excluding Tax]),
            FORMAT_STRING = "Currency",
            VISIBLE = 1;
            
            /* Rolling 12-Month Profit */
            CREATE MEMBER CURRENTCUBE.[Measures].[Rolling 12M Profit]
            AS SUM(LastPeriods(12, [Date].[Calendar].[Month].CurrentMember), [Measures].[Profit]),
            FORMAT_STRING = "Currency",
            VISIBLE = 1;
            
            /* Rolling 12-Month Margin Percentage */
            CREATE MEMBER CURRENTCUBE.[Measures].[Rolling 12M Margin %]
            AS [Measures].[Rolling 12M Profit] / [Measures].[Rolling 12M Revenue] * 100,
            FORMAT_STRING = "0.00%",
            VISIBLE = 1;
            
            /* Revenue Trend Indicator */
            CREATE MEMBER CURRENTCUBE.[Measures].[Revenue Trend]
            AS IIF([Measures].[Revenue MoM Growth %] > 0, "↗ Up", 
                   IIF([Measures].[Revenue MoM Growth %] < 0, "↘ Down", "→ Flat")),
            VISIBLE = 1;
            
            /* Previous Year Same Month Revenue */
            CREATE MEMBER CURRENTCUBE.[Measures].[Revenue PY Same Month]
            AS ([Measures].[Revenue Excluding Tax], ParallelPeriod([Date].[Calendar].[Month], 12)),
            FORMAT_STRING = "Currency",
            VISIBLE = 1;
            
            /* Previous Month Revenue */
            CREATE MEMBER CURRENTCUBE.[Measures].[Revenue Previous Month]
            AS ([Measures].[Revenue Excluding Tax], [Date].[Calendar].CurrentMember.PrevMember),
            FORMAT_STRING = "Currency",
            VISIBLE = 1;
            
            /* 3-Month Moving Average Revenue */
            CREATE MEMBER CURRENTCUBE.[Measures].[3Month Avg Revenue]
            AS AVG(LastPeriods(3, [Date].[Calendar].[Month].CurrentMember), [Measures].[Revenue Excluding Tax]),
            FORMAT_STRING = "Currency",
            VISIBLE = 1;
            
            /* Revenue per Customer */
            CREATE MEMBER CURRENTCUBE.[Measures].[Revenue per Customer]
            AS [Measures].[Revenue Excluding Tax] / [Measures].[Invoice Count],
            FORMAT_STRING = "Currency",
            VISIBLE = 1;
          </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>
