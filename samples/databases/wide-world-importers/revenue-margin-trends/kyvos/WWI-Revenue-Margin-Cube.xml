<?xml version="1.0" encoding="UTF-8"?>
<Cube xmlns="http://schemas.microsoft.com/analysisservices/2003/engine" 
      xmlns:xsd="http://www.w3.org/2001/XMLSchema" 
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ID>WWI Revenue Margin Cube</ID>
  <Name>WWI Revenue Margin Cube</Name>
  <Description>Wide World Importers Revenue and Margin Analysis Cube for 12-month trend analysis</Description>
  
